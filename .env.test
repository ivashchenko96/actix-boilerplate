# Test Database Configuration
DATABASE_URL=postgresql://test_user:test_pass@localhost:5432/actix_boilerplate_test

# Test Redis Configuration
REDIS_URL=redis://localhost:6379/1

# Test NATS Configuration
NATS_URL=nats://localhost:4222

# Test Email Configuration (use mailhog or similar for testing)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=test
SMTP_PASSWORD=test
FROM_EMAIL=test@example.com

# Test AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test-key
AWS_SECRET_ACCESS_KEY=test-secret
S3_BUCKET_NAME=test-bucket

# Test JWT Configuration
JWT_SECRET=test-jwt-secret-key-for-testing-only
JWT_ACCESS_EXPIRATION=300
JWT_REFRESH_EXPIRATION=3600

# Test Server Configuration
HOST=localhost
PORT=8001
WORKERS=1
LOG_LEVEL=debug
ENVIRONMENT=test

# Test Typesense Configuration
TYPESENSE_API_KEY=test-api-key
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108

# Test Feature Flags
FEATURE_REGISTRATION_ENABLED=true
FEATURE_EMAIL_VERIFICATION=false
FEATURE_PASSWORD_RESET=true
FEATURE_RATE_LIMITING=false

# Test CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID

# Test Security Headers
CSP_POLICY="default-src 'self'"
HSTS_MAX_AGE=3600

# Test Application Configuration
APP_NAME="Actix Boilerplate Test"
APP_VERSION=0.1.0-test
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ar,de

# Test Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_BURST_SIZE=1000

# Test Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=50